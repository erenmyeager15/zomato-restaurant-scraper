{
  "actorSpecification": 1,
  "name": "zomato-restaurant-scraper",
  "title": "Zomato Restaurant Scraper - Listings, Ratings & Prices",
  "description": "Scrape public Zomato restaurant listings with names, cuisines, ratings, review counts, pricing, locality, images, and restaurant URLs. Useful for restaurant market research and local food data monitoring.",
  "version": "1.0",
  "buildTag": "latest",
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "output": "./output_schema.json",
  "categories": ["OTHER", "ECOMMERCE"],
  "categoriesVersion": "1.0.0",
  "exampleRunInput": {
    "body": "{\"city\":\"Mumbai\",\"searchQueries\":[\"pizza\"],\"categories\":[],\"minRating\":0,\"maxResults\":1,\"proxyConfiguration\":{\"useApifyProxy\":true,\"apifyProxyGroups\":[\"RESIDENTIAL\"],\"apifyProxyCountry\":\"IN\"}}",
    "contentType": "application/json"
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts. Number of events depends on memory (one per GB, minimum one).",
          "eventPriceUsd": 0.00005,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        },
        "restaurant-scraped": {
          "eventTitle": "Restaurant scraped",
          "eventDescription": "Charged once for each clean Zomato restaurant record saved to the dataset.",
          "eventPriceUsd": 0.003,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        }
      }
    }
  },
  "storages": {
    "dataset": "./dataset_schema.json"
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 4096,
    "timeoutSecs": 3600
  },
  "minMemoryMbytes": 4096,
  "maxMemoryMbytes": 4096
}
